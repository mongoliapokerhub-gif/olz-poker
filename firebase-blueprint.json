{
  "entities": {
    "LoginRecord": {
      "title": "Login Record",
      "description": "A record of a user login attempt.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The username entered."
        },
        "passwordHash": {
          "type": "string",
          "description": "The hashed password."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the login occurred."
        }
      },
      "required": [
        "username",
        "passwordHash",
        "timestamp"
      ]
    }
  },
  "firestore": {
    "logins/{loginId}": {
      "schema": "LoginRecord",
      "description": "Collection of login attempts."
    }
  }
}
